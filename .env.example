# Copy to `.env.development` for local work (used by `next dev` and Drizzle CLI).
# See README.md for setup.

# Google Gemini — required for assistant replies
GEMINI_API_KEY=

# PostgreSQL — required (tables live under schema `demo`)
PG_HOST=localhost
PG_PORT=5432
PG_USERNAME=postgres
PG_PASSWORD=postgres
PG_DATABASE=my_app

# Optional: use "true" for managed Postgres that requires TLS
# PG_SSL=false
